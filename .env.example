# ============================================================
# jam_transformer — 환경 변수 템플릿
#
# 사용법:
#   cp .env.example .env
#   .env 파일을 열어서 실제 값을 채운다
#
# .env는 git과 번들에서 제외됨 — 절대 커밋하지 말 것.
# ============================================================

# ------------------------------------------------------------------
# Weights & Biases (선택 — 없으면 CSV 로거로 자동 대체)
# 발급: https://wandb.ai/settings → API keys
# 핸드폰에서도 실시간으로 loss 곡선 확인 가능
# ------------------------------------------------------------------
WANDB_API_KEY=

# W&B에서 보이는 run 이름 (비워두면 RUN_NAME 타임스탬프로 자동 설정)
WANDB_NAME=

# W&B를 완전히 끄고 싶을 때 (1/true/yes 로 설정)
# WANDB_DISABLED=true

# ------------------------------------------------------------------
# HuggingFace (선택 — private 데이터셋/모델 사용 시에만 필요)
# 발급: https://huggingface.co/settings/tokens
# ------------------------------------------------------------------
HF_TOKEN=

# ------------------------------------------------------------------
# 플랫폼별 Auto-shutdown 설정
#
# ┌─────────────────┬──────────────────────────────────────────────┐
# │ 플랫폼          │ 필요한 설정                                  │
# ├─────────────────┼──────────────────────────────────────────────┤
# │ RunPod          │ RUNPOD_API_KEY 필수                          │
# │                 │   없으면 학습 종료 후에도 Pod가 계속 과금됨 │
# │                 │   RUNPOD_POD_ID는 RunPod가 자동 주입         │
# ├─────────────────┼──────────────────────────────────────────────┤
# │ Vast.ai         │ RUNPOD_API_KEY 불필요                        │
# │                 │   종료: shutdown -h now (특권 컨테이너) 또는 │
# │                 │   Vast.ai 콘솔 → Destroy/Stop 직접 클릭      │
# │                 │   또는 인스턴스 max_days 설정으로 자동 종료  │
# ├─────────────────┼──────────────────────────────────────────────┤
# │ 앨리스·기타 클라우드 │ RUNPOD_API_KEY 불필요                   │
# │                 │   AUTO_SHUTDOWN=1이면 shutdown -h now 시도   │
# │                 │   VM이면 동작, 비특권 컨테이너면 수동 종료   │
# ├─────────────────┼──────────────────────────────────────────────┤
# │ 다른 컴퓨터     │ RUNPOD_API_KEY 불필요                        │
# │                 │   shutdown -h now로 정상 종료                 │
# └─────────────────┴──────────────────────────────────────────────┘
#
# RUNPOD_API_KEY : 발급: https://www.runpod.io/console/user/settings → API Keys
# RUNPOD_POD_ID  : RunPod가 컨테이너 시작 시 자동으로 주입 — 직접 입력 불필요
# ------------------------------------------------------------------
RUNPOD_API_KEY=